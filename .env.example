# ─────────────────────────────────────────────────────────────────────────────
# Hive — Environment Variables
# Copy this file to .env and fill in your values.
# These are used by Docker Compose and referenced in config.yaml as ${VAR_NAME}
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
HIVE_TOKEN=changeme          # Token required to unlock editing in the UI

# ── Infrastructure ────────────────────────────────────────────────
PROXMOX_TOKEN=               # USER@REALM!TOKENID=SECRET
PORTAINER_TOKEN=             # Account → Access Tokens

# ── Networking ────────────────────────────────────────────────────
ADGUARD_USER=
ADGUARD_PASS=
PIHOLE_TOKEN=                # v5: API token  |  v6: admin password
NPM_USER=
NPM_PASS=

# ── Monitoring ────────────────────────────────────────────────────
GRAFANA_TOKEN=               # Service account token
UPTIMEKUMA_USER=
UPTIMEKUMA_PASS=

# ── Media ─────────────────────────────────────────────────────────
JELLYFIN_TOKEN=
PLEX_TOKEN=
EMBY_TOKEN=
SONARR_APIKEY=
RADARR_APIKEY=
LIDARR_APIKEY=
READARR_APIKEY=
PROWLARR_APIKEY=
BAZARR_APIKEY=
OVERSEERR_APIKEY=
JELLYSEERR_APIKEY=

# ── Download clients ──────────────────────────────────────────────
QB_USER=
QB_PASS=
TR_USER=
TR_PASS=
DELUGE_PASS=
SABNZBD_APIKEY=
NZBGET_USER=
NZBGET_PASS=

# ── System ────────────────────────────────────────────────────────
TRUENAS_APIKEY=
SYNO_USER=
SYNO_PASS=
UNIFI_USER=
UNIFI_PASS=
OPNS_KEY=
OPNS_SECRET=
WATCHTOWER_TOKEN=

# ── Storage ───────────────────────────────────────────────────────
WD_USER=
WD_PASS=

# ── Services & Tools ──────────────────────────────────────────────
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
IMMICH_APIKEY=
HASS_TOKEN=
GITLAB_TOKEN=
GITEA_TOKEN=
FORGEJO_TOKEN=
PAPERLESS_TOKEN=
FIREFLY_TOKEN=

# ── Network ───────────────────────────────────────────────────────
CF_TOKEN=
CF_ACCOUNT_ID=
TS_APIKEY=
TS_TAILNET=
